            },
            {
                "title": "Modern Tools",
                "content": "Get introduced to TailwindCSS, GitHub, Firebase, and Postman to build full-stack apps."
            },
            {
                "title": "Project Ready",
                "content": "By the end of the course, deploy your project online and build your web developer portfolio."
            }
